APP_NAME=LaLaDia
APP_ENV=local
# PRODUCTION: Set to false. Never expose stack traces to users.
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
# PRODUCTION: Set to 'error' or 'warning'. 'debug' logs every query value and
# stack frame — high disk usage and leaks internal details to log files.
LOG_LEVEL=debug

DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# PRODUCTION: Switch to 'redis' to avoid write contention on the sessions table
# under concurrent load. Requires REDIS_HOST/REDIS_PORT to be set.
SESSION_DRIVER=database
SESSION_LIFETIME=120
# PRODUCTION: Must be true. Session payloads contain auth tokens, order data,
# and customer PII — encrypting them protects against DB-level data exposure.
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# PRODUCTION: Switch to 'redis'. The database driver serialises all jobs through
# a single table — under load, queue workers contend on row-level locks.
QUEUE_CONNECTION=database

# PRODUCTION: Switch to 'redis' for sub-millisecond reads and no DB contention.
CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Sanctum token expiration in minutes. null = rely on code-level expiry only.
# PRODUCTION: Set to 10080 (7 days) so the framework prunes expired tokens.
SANCTUM_TOKEN_EXPIRATION=10080

VITE_APP_NAME="${APP_NAME}"

# Admin notification contacts
ADMIN_PHONE=01XXXXXXXXX
ADMIN_EMAIL=admin@example.com

# ── Conversion Tracking ──────────────────────────────────────────────────────
#
# ARCHITECTURE:
#   GTM_ID        — loads GTM on every page. GTM owns ALL browser-side tracking
#                   (GA4 tags, Meta Pixel init, PageView, ecommerce events).
#   META_PIXEL_ID — used ONLY by the server-side PHP CAPI job (SendConversionEvents).
#                   The pixel is NOT hard-coded in any Blade layout; GTM handles it.
#   GA4_*         — used ONLY by the server-side GA4 Measurement Protocol job.
#                   GA4 browser collection goes through GTM, not a hard-coded snippet.
#
# IMPORTANT: Do NOT add fbq() or gtag() scripts directly to Blade layouts.
#            GTM is the single entry point for all browser tracking.

# Google Tag Manager container ID — from GTM > Admin > Install Google Tag Manager
GTM_ID=GTM-XXXXXXX

# Meta Pixel ID — from Meta Events Manager > Datasets > your pixel
# Used for server-side CAPI only. GTM handles browser-side pixel loading.
META_PIXEL_ID=

# System User access token with ads_management + ads_read permissions
# Generate from: Meta Business Manager > System Users > your user > Generate Token
META_ACCESS_TOKEN=

# TESTING ONLY — uncomment and set during CAPI testing. Remove before going live.
# META_TEST_EVENT_CODE=TEST12345

# GA4 Measurement ID — from GA4 Admin > Data Streams > Web > Measurement ID
# Used for server-side Measurement Protocol only. GTM handles browser GA4.
GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# GA4 Measurement Protocol API Secret
# Generate from: GA4 Admin > Data Streams > Web stream > Measurement Protocol API Secrets
GA4_API_SECRET=

# Comma-separated IPs excluded from all server-side conversion events
# Private/loopback ranges (127.x, 192.168.x, 10.x) are always excluded automatically
TRACKING_EXCLUDED_IPS=
