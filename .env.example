APP_NAME=LaLaDia
APP_ENV=local
# PRODUCTION: Set to false. Never expose stack traces to users.
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
# PRODUCTION: Set to 'error' or 'warning'. 'debug' logs every query value and
# stack frame — high disk usage and leaks internal details to log files.
LOG_LEVEL=debug

DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# PRODUCTION: Switch to 'redis' to avoid write contention on the sessions table
# under concurrent load. Requires REDIS_HOST/REDIS_PORT to be set.
SESSION_DRIVER=database
SESSION_LIFETIME=120
# PRODUCTION: Must be true. Session payloads contain auth tokens, order data,
# and customer PII — encrypting them protects against DB-level data exposure.
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# PRODUCTION: Switch to 'redis'. The database driver serialises all jobs through
# a single table — under load, queue workers contend on row-level locks.
QUEUE_CONNECTION=database

# PRODUCTION: Switch to 'redis' for sub-millisecond reads and no DB contention.
CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Sanctum token expiration in minutes. null = rely on code-level expiry only.
# PRODUCTION: Set to 10080 (7 days) so the framework prunes expired tokens.
SANCTUM_TOKEN_EXPIRATION=10080

VITE_APP_NAME="${APP_NAME}"

# Admin notification contacts
ADMIN_PHONE=01XXXXXXXXX
ADMIN_EMAIL=admin@example.com

# ── Conversion Tracking ──────────────────────────────────────────────────────

# Comma-separated IPs excluded from conversion tracking (e.g. office/dev IPs)
TRACKING_EXCLUDED_IPS=

GTM_ID=GTM-XXXXXXX

META_PIXEL_ID=                    # Meta Pixel ID — from Events Manager > Datasets
META_ACCESS_TOKEN=                # System user access token with ads_management permission
# META_TEST_EVENT_CODE=TEST12345  # TESTING ONLY — remove before going live

GA4_MEASUREMENT_ID=G-XXXXXXXXXX   # From GA4 Admin > Data Streams > Web stream
GA4_API_SECRET=                   # From GA4 Admin > Data Streams > Measurement Protocol API secrets
